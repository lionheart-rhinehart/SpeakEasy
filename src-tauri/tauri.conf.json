{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SpeakEasy",
  "version": "1.0.6",
  "identifier": "com.speakeasy.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SpeakEasy",
        "label": "main",
        "width": 550,
        "height": 750,
        "minWidth": 450,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": true,
        "visible": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/lionheart-rhinehart/SpeakEasy/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc0NUM0RUUyNjBCOEQ2MkQKUldRdDFyaGc0azVjZEg5WGYrTTlPbHZJcXl4S0ZtNXJ5ZXVDcjlXK1JSb2oxeFd1VHY1akpDZVEK"
    }
  }
}
