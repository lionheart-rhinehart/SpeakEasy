{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SpeakEasy",
  "version": "1.0.0",
  "identifier": "com.speakeasy.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SpeakEasy",
        "label": "main",
        "width": 550,
        "height": 750,
        "minWidth": 450,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": true,
        "visible": true,
        "focus": true
      },
      {
        "title": "Recording",
        "label": "recording-overlay",
        "url": "overlay.html",
        "width": 300,
        "height": 80,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "focus": false,
        "skipTaskbar": true,
        "x": 0,
        "y": 0
      },
      {
        "title": "Status",
        "label": "status-bar",
        "url": "statusbar.html",
        "width": 220,
        "height": 80,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "visibleOnAllWorkspaces": true
      },
      {
        "title": "Voice Review",
        "label": "voice-review",
        "url": "voice-review.html",
        "width": 400,
        "height": 300,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": true
      },
      {
        "title": "Profile Chooser",
        "label": "profile-chooser",
        "url": "profile-chooser.html",
        "width": 350,
        "height": 400,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
